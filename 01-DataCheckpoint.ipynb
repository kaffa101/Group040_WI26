    "def drop_rate(course):\n",
    "    diff = course['enrolled'].diff().fillna(0)\n",
    "    total_enroll = int(diff[diff > 0].sum())\n",
    "    total_drop = int((-diff[diff < 0]).sum())\n",
    "    drop_rate = round((total_drop/total_enroll) * 100, 2)\n",
    "    print(total_enroll)\n",
    "    print(total_drop)\n",
    "    print('The drop rate is ' + str(drop_rate) + '%')\n",
    "\n"
   ]
  },
