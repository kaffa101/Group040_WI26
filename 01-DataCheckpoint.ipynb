    "import pandas as pd\n",
    "capes_data = pd.read_csv('data/00-raw/capes_data.csv')\n",
    "print(capes_data.shape)\n",
    "capes_clean = capes_data.drop(['Instructor', 'Total Enrolled in Course', \\\n",
