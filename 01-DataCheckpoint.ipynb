    "capes_cogs = capes_clean[capes_clean['Course'].str.contains('COGS ')]\n",
    "quar_interval = ['FA22', 'WI23', 'SP23']\n",
    "capes_clean = capes_cogs[capes_cogs['Quarter'].isin(quar_interval)]\n",
    "capes_clean = capes_clean.dropna()\n",
    "# drop rows containing null\n",
    "capes_clean.to_csv(\"data/02-processed/capes_clean.csv\", index=False)\n",
    "capes_clean\n",
